# Copy this file to .env to configure a local run.
# conftest.py loads this automatically via python-dotenv — no manual
# `export` needed.

# Required. Reqres now requires an x-api-key header on every request.
# Get a free key at https://reqres.in/signup
REQRES_API_KEY=your_reqres_api_key_here

# Optional. Overrides the API base URL. Priority order when tests run:
#   1. pytest --base-url <url>   (command-line flag, highest priority)
#   2. BASE_URL below (or set as a real environment variable)
#   3. https://reqres.in         (built-in default in conftest.py)
BASE_URL=https://reqres.in
